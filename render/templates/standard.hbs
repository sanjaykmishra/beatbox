<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{report.title}} — {{client.name}}</title>
  <style>
    :root {
      --primary: #{{branding.primary_color}};
      --ink: #111827;
      --ink-soft: #4b5563;
      --line: #e5e7eb;
      --bg: #ffffff;
      --bg-soft: #f9fafb;
    }
    * { box-sizing: border-box; }
    @page { size: Letter; margin: 0.5in; }
    html, body {
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      color: var(--ink);
      background: var(--bg);
      font-size: 10.5pt;
      line-height: 1.45;
    }
    section { page-break-inside: avoid; }
    .page-break { page-break-after: always; }
    h1, h2, h3 { color: var(--ink); margin: 0 0 0.4em; font-weight: 600; }
    h1 { font-size: 28pt; letter-spacing: -0.01em; line-height: 1.1; }
    h2 { font-size: 14pt; border-bottom: 1px solid var(--line); padding-bottom: 6px; margin-top: 28px; }
    h3 { font-size: 11pt; }
    p { margin: 0 0 0.6em; }
    .muted { color: var(--ink-soft); font-size: 9pt; }

    /* ----- Cover ----- */
    .cover {
      min-height: 9.2in;
      display: flex;
      flex-direction: column;
      padding: 0.4in 0;
    }
    .cover-header { display: flex; align-items: center; gap: 14px; }
    .cover-header .logo {
      width: 44px; height: 44px; border-radius: 6px; object-fit: cover; background: var(--bg-soft);
    }
    .cover-header .agency-name { font-weight: 600; font-size: 11pt; color: var(--ink-soft); }
    .cover-band { flex: 1; display: flex; flex-direction: column; justify-content: center; }
    .cover-eyebrow { color: var(--primary); font-weight: 600; font-size: 11pt; letter-spacing: 0.04em; text-transform: uppercase; }
    .cover-title { font-size: 36pt; font-weight: 700; letter-spacing: -0.02em; line-height: 1.05; margin-top: 8px; }
    .cover-period { font-size: 13pt; color: var(--ink-soft); margin-top: 14px; }

    /* ----- Executive summary ----- */
    .summary p:first-child::first-line { font-weight: 500; }

    /* ----- At a glance ----- */
    .glance { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 8px; }
    .glance .tile {
      background: var(--bg-soft);
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 14px;
    }
    .glance .label { color: var(--ink-soft); font-size: 9pt; text-transform: uppercase; letter-spacing: 0.04em; }
    .glance .value { font-size: 22pt; font-weight: 700; margin-top: 4px; color: var(--ink); }
    .glance .accent { border-top: 3px solid var(--primary); }

    /* ----- Highlights ----- */
    .highlights { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .highlight {
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 14px;
      display: flex;
      gap: 12px;
    }
    .highlight .thumb {
      width: 84px; height: 56px; flex: none; background: var(--bg-soft); border-radius: 4px; object-fit: cover;
    }
    .highlight .meta { color: var(--ink-soft); font-size: 8.5pt; }
    .highlight .headline { font-weight: 600; font-size: 10.5pt; margin-top: 2px; }
    .highlight .lede { color: var(--ink-soft); font-size: 9pt; margin-top: 4px; }

    /* ----- Coverage list ----- */
    .coverage-list { list-style: none; padding: 0; margin: 0; }
    .coverage-item { padding: 12px 0; border-bottom: 1px solid var(--line); display: flex; gap: 12px; }
    .coverage-item:last-child { border-bottom: none; }
    .coverage-item .thumb { width: 84px; height: 56px; flex: none; background: var(--bg-soft); border-radius: 4px; object-fit: cover; }
    .coverage-item .info { flex: 1; min-width: 0; }
    .coverage-item .info .meta { color: var(--ink-soft); font-size: 8.5pt; display: flex; gap: 8px; flex-wrap: wrap; }
    .coverage-item .info .headline { font-weight: 600; margin-top: 2px; }
    .coverage-item .info .summary { color: var(--ink-soft); font-size: 9pt; margin-top: 4px; }
    .badge { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 8pt; }
    .badge.tier-1 { background: var(--primary); color: white; }
    .badge.tier-2 { background: var(--bg-soft); color: var(--ink); border: 1px solid var(--line); }
    .badge.tier-3 { background: var(--bg-soft); color: var(--ink-soft); border: 1px solid var(--line); }
    .badge.sentiment-positive { background: #ecfdf5; color: #065f46; }
    .badge.sentiment-neutral { background: var(--bg-soft); color: var(--ink-soft); }
    .badge.sentiment-mixed { background: #fef3c7; color: #92400e; }
    .badge.sentiment-negative { background: #fee2e2; color: #991b1b; }

    /* ----- Social mentions ----- */
    .social-list { list-style: none; padding: 0; margin: 0; }
    .social-item { padding: 12px 0; border-bottom: 1px solid var(--line); display: flex; gap: 12px; }
    .social-item:last-child { border-bottom: none; }
    .social-item .avatar {
      width: 40px; height: 40px; flex: none; background: var(--bg-soft);
      border-radius: 50%; object-fit: cover;
    }
    .social-item .info { flex: 1; min-width: 0; }
    .social-item .info .meta { color: var(--ink-soft); font-size: 8.5pt; display: flex; gap: 8px; flex-wrap: wrap; }
    .social-item .info .author { font-weight: 600; color: var(--ink); }
    .social-item .info .body { font-size: 10pt; margin-top: 4px; white-space: pre-wrap; }
    .social-item .info .summary { color: var(--ink-soft); font-size: 9pt; margin-top: 4px; font-style: italic; }
    .social-item .info .engagement { color: var(--ink-soft); font-size: 8.5pt; margin-top: 6px; }
    .platform-badge {
      display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 8pt;
      background: var(--bg-soft); color: var(--ink); border: 1px solid var(--line);
    }

    /* ----- Screen-only styling -----
       The template above is PDF-first (Letter page size, half-inch @page margins).
       /render emulates print media via puppeteer so this @media screen block doesn't
       apply there. /preview and the public share view render in a browser and need
       a max-width container, padding, and a smaller cover band so the page doesn't
       open with a giant blank top section. */
    @media screen {
      body {
        background: var(--bg-soft);
        padding: 32px 16px 64px;
      }
      body > section, body > div.page-break + section, body > section + section {
        max-width: 880px;
        margin-left: auto;
        margin-right: auto;
      }
      body > section {
        background: var(--bg);
        padding: 24px 32px;
        border: 1px solid var(--line);
        border-radius: 8px;
        margin-bottom: 16px;
        font-size: 13px;
        line-height: 1.5;
      }
      .cover {
        /* Base PDF rule sets min-height: 9.2in (whole-page cover) and padding: 0.4in 0 (zero
           horizontal). For screen mode we want the cover card to look like the other section
           cards — same vertical breathing room as the Executive Summary card below. Reset
           min-height to 0 and inherit padding from `body > section { padding: 24px 32px }`
           by clearing the base shorthand. */
        min-height: 0;
        padding: 24px 32px;
      }
      .cover-title { font-size: 32px; }
      .cover-period { font-size: 14px; margin-top: 8px; }
      .cover-eyebrow { font-size: 11px; }
      h2 { font-size: 16px; padding-bottom: 8px; margin-top: 8px; }
      h2:first-child { margin-top: 0; }
      h1 { font-size: 28px; }
      .glance .value { font-size: 24px; }
      .glance .label { font-size: 10px; }
      .highlight .thumb, .coverage-item .thumb {
        width: 96px; height: 64px;
      }
      .page-break { display: none; }
    }
  </style>
</head>
<body>

  <!-- COVER -->
  <section class="cover">
    <div class="cover-header">
      {{#if branding.logo_url}}
        <img class="logo" src="{{branding.logo_url}}" alt="" />
      {{else}}
        <div class="logo"></div>
      {{/if}}
      <div class="agency-name">{{branding.agency_name}}</div>
    </div>
    <div class="cover-band">
      <div class="cover-eyebrow">Coverage report</div>
      <div class="cover-title">{{client.name}}</div>
      <div class="cover-period">{{report.period_label}}</div>
    </div>
  </section>
  <div class="page-break"></div>

  <!-- EXECUTIVE SUMMARY -->
  <section class="summary">
    <h2>Executive summary</h2>
    {{#if report.executive_summary}}
      {{#each report.executive_summary_paragraphs}}
        <p>{{this}}</p>
      {{/each}}
    {{else}}
      <p class="muted">Executive summary will be generated when the report is finalized.</p>
    {{/if}}
  </section>

  <!-- AT A GLANCE -->
  <section>
    <h2>At a glance</h2>
    <div class="glance">
      <div class="tile accent">
        <div class="label">Total coverage</div>
        <div class="value">{{glance.total}}</div>
      </div>
      <div class="tile">
        <div class="label">Tier-1</div>
        <div class="value">{{glance.tier_1}}</div>
      </div>
      <div class="tile">
        <div class="label">Outlets</div>
        <div class="value">{{glance.outlets}}</div>
      </div>
      <div class="tile">
        <div class="label">Estimated reach</div>
        <div class="value">{{glance.reach_human}}</div>
      </div>
    </div>
    {{#if glance.missing_count}}
      <p class="muted" style="margin-top:10px">
        {{glance.missing_count}} additional item(s) added to this report did not mention
        {{client.name}}; excluded from the counts above.
      </p>
    {{/if}}
  </section>

  <!-- HIGHLIGHTS — unified across articles + social posts. Each highlight carries `kind`
       ("article" | "social") and the template branches on it for the per-card chrome
       (article: tier badge + outlet; social: platform label + author handle). -->
  {{#if highlights.length}}
  <section>
    <h2>Highlights</h2>
    <div class="highlights">
      {{#each highlights}}
        <div class="highlight">
          {{#if screenshot_url}}
            <img class="thumb" src="{{screenshot_url}}" alt="" />
          {{else}}
            <div class="thumb"></div>
          {{/if}}
          <div>
            <div class="meta">
              {{#if outlet_name}}{{outlet_name}}{{/if}}
              {{#if author_handle}} · {{author_handle}}{{/if}}
              {{#if publish_date}} · {{publish_date}}{{/if}}
              {{#if tier}} · <span class="badge tier-{{tier}}">Tier {{tier}}</span>{{/if}}
            </div>
            <div class="headline">{{headline}}</div>
            {{#if lede}}<div class="lede">{{lede}}</div>{{/if}}
          </div>
        </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  <!-- COVERAGE LIST — hidden entirely when there are no substantive items, since an empty list
       under the "Coverage" heading reads like a render bug to the share-link recipient. The
       'N additional items did not mention …' footnote on at-a-glance already explains where
       any off-topic URLs went. -->
  {{#if coverage_items.length}}
  <section>
    <h2>Coverage</h2>
    <ul class="coverage-list">
      {{#each coverage_items}}
        <li class="coverage-item">
          {{#if screenshot_url}}
            <img class="thumb" src="{{screenshot_url}}" alt="" />
          {{else}}
            <div class="thumb"></div>
          {{/if}}
          <div class="info">
            <div class="meta">
              {{#if outlet_name}}<span>{{outlet_name}}</span>{{/if}}
              {{#if publish_date}}<span>{{publish_date}}</span>{{/if}}
              {{#if tier}}<span class="badge tier-{{tier}}">Tier {{tier}}</span>{{/if}}
              {{#if sentiment}}<span class="badge sentiment-{{sentiment}}">{{sentiment}}</span>{{/if}}
            </div>
            <div class="headline">{{headline}}</div>
            {{#if summary}}
              <div class="summary">{{summary}}</div>
            {{else if lede}}
              <div class="summary">{{lede}}</div>
            {{/if}}
          </div>
        </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  <!-- SOCIAL MENTIONS — separate from Coverage because the visual treatment differs (avatar +
       handle + engagement counts + post body) and mixing both into one list reads poorly per
       wireframe-31. Hidden when there are no substantive social mentions. -->
  {{#if social_mentions.length}}
  <section>
    <h2>Social mentions</h2>
    <ul class="social-list">
      {{#each social_mentions}}
        <li class="social-item">
          {{#if author_avatar_url}}
            <img class="avatar" src="{{author_avatar_url}}" alt="" />
          {{else}}
            <div class="avatar"></div>
          {{/if}}
          <div class="info">
            <div class="meta">
              {{#if author_display_name}}<span class="author">{{author_display_name}}</span>{{/if}}
              {{#if author_handle}}<span>{{author_handle}}</span>{{/if}}
              {{#if platform}}<span class="platform-badge">{{platform}}</span>{{/if}}
              {{#if posted_date}}<span>{{posted_date}}</span>{{/if}}
              {{#if sentiment}}<span class="badge sentiment-{{sentiment}}">{{sentiment}}</span>{{/if}}
            </div>
            {{#if content_text}}
              <div class="body">{{content_text}}</div>
            {{/if}}
            {{#if summary}}
              <div class="summary">{{summary}}</div>
            {{/if}}
            <div class="engagement">
              {{likes_human}} likes · {{reposts_human}} reposts · {{replies_human}} replies
            </div>
          </div>
        </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

</body>
</html>
